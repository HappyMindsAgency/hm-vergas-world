---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { INDIZI } from "../data/indizi.ts";
import { GAME_TIMEZONE, INDIZIO_MARKERS } from "../config/game.ts";
import "../styles/styles.css"; // token + stili di Header/Footer condivisi
import "../styles/home.css"; // stili specifici della home (Figma 75-766)

// Build statica: la rotazione giornaliera va calcolata nel browser (ADR-4).
// Esportiamo l'intero pool + costanti al client; indizio.js seleziona l'oggetto
// del giorno al view-time. Fonte unica: src/data + src/config.
const indizioData = {
  indizi: INDIZI,
  timeZone: GAME_TIMEZONE,
  markerCount: INDIZIO_MARKERS,
};

// Le 7 tappe del museo (Figma 75:773–75:800). Sono etichette di presentazione
// della mappa, non un contratto condiviso: il nome della stanza del museo.
const TAPPE = [
  "Il Palazzo",
  "La Chiesa sulla collina",
  "La Giara",
  "L'Orto",
  "Il Salotto",
  "Il Villaggio",
  "Verga, il ritratto",
];

// Personaggi (Figma 75:850). Immagini dagli asset esistenti in /public/immagini.
const PERSONAGGI = [
  { nome: "Carletto", ruolo: "Il viaggiatore", img: "/immagini/carletto.jpg",
    desc: "Arriva da Milano con il vestito in ordine e la testa piena di noia. A Vizzini scopre che anche un sasso può contenere una storia intera." },
  { nome: "Caterina", ruolo: "La guida", img: "/immagini/Caterina.jpg",
    desc: "Conosce vicoli, cortili e scorci nascosti. Non spiega troppo: prende Carletto per mano e lo porta dove iniziano le avventure." },
  { nome: "Giovanni Verga", ruolo: "Il padrone di casa", img: "/immagini/palazzo di verga.jpg",
    desc: "Nel suo palazzo gli adulti parlano e brindano. Fuori, intanto, le sue storie prendono vita tra i vicoli di Vizzini." },
  { nome: "Gesualdo", ruolo: "Il collezionista", img: "/immagini/incontro con gesualdo.jpg",
    desc: "Vive in un cortile pieno di oggetti dimenticati. Difende il suo regno con diffidenza, finché un dono gli mostra che le cose diventano più belle quando si condividono." },
  { nome: "Rosso Malpelo", ruolo: "Il genio incompreso", img: "/immagini/malpelo.jpg",
    desc: "Disegna nella sabbia canali, numeri e mappe. Ha mani sporche e capelli rossi, ma dentro la grotta accende la lezione più luminosa." },
];

// Slide dello slider storie (Figma 75:946). La copy di storia 1 è quella del
// design; per le altre usiamo titolo della tappa + sinossi della storia seedata.
// ponytail: l'editoria riempirà le sinossi definitive; qui riusiamo INDIZI.
const STORIE = TAPPE.map((tappa, i) => ({
  numero: i + 1,
  tappa,
  titolo: i === 0 ? "L'inizio del viaggio" : INDIZI[i]?.storiaTitolo ?? tappa,
  immagine: INDIZI[i]?.immagine ?? "/immagini/figma-mappa-vizzini.png",
  descrizione:
    i === 0
      ? "Carletto è tornato a Milano, ma ha ancora Vizzini nella testa. Nella valigia trova un sasso colorato e il ricordo si apre: Palazzo Verga, una tavola piena di adulti, un panino rubato sotto la tovaglia e Caterina, pronta a portarlo fuori, dove comincia davvero l'avventura."
      : INDIZI[i]?.descrizioneStoria ?? "",
}));
---

<BaseLayout
  title="Verga's World | Casa Verga Vizzini"
  description="Esplora Vizzini attraverso 7 storie animate, indizi nascosti e attività da sbloccare durante la visita al museo R.I.V.I.V.I."
  fonts="none"
  scripts={[
    { src: "/scripts/indizio.js", defer: true },
    { src: "/scripts/home-slider.js", defer: true },
  ]}
>
  <Header />

  <main id="main-content" class="vw-home">
    <!-- HERO (75:928) -->
    <section class="vw-hero" aria-labelledby="hero-title">
      <div class="vw-hero__intro">
        <img class="vw-hero__logo" src="/immagini/figma-logo-vergas-world.png" alt="Verga's World" id="hero-title" width="606" height="243" fetchpriority="high" />
        <p class="vw-hero__lead">
          Esplora Vizzini attraverso <strong>7 storie animate, indizi nascosti</strong>
          e attività da sbloccare durante la visita al museo R.I.V.I.V.I.
        </p>
        <div class="vw-hero__actions">
          <a class="vw-btn vw-btn--primary" href="/#visita">Prenota la visita</a>
          <a class="vw-btn vw-btn--ghost" href="/avventura">Ho un codice avventura →</a>
        </div>
      </div>
    </section>

    <!-- MAPPA + BOX INDIZIO (75:769 + 75:1016) -->
    <section class="vw-map-section" id="mappa" aria-labelledby="mappa-title">
      <h2 id="mappa-title" hidden>Mappa illustrata di Vizzini</h2>

      <!-- Tab tappe in una riga in cima alla mappa (75:773–75:800) -->
      <div class="vw-tappe" role="list" aria-label="Le tappe del museo">
        {TAPPE.map((nome, i) => (
          <span class="vw-tappa" role="listitem">
            <span class="vw-tappa__num">{i + 1}</span>
            <span>{nome}</span>
          </span>
        ))}
      </div>

      <!-- La mappa è una illustrazione panoramica grande, a tutta larghezza.
           Il box indizio le galleggia sopra l'angolo top-right (desktop). -->
      <div class="vw-map-overlay">
        <div class="vw-map-stage" data-clue-map aria-label="Mappa illustrata interattiva di Vizzini">
          <img class="vw-map-stage__img" src="/immagini/figma-mappa-vizzini.png" alt="Mappa illustrata del paese di Vizzini con le tappe del museo" decoding="async" />
          <!-- Le lenti "indizio" sono iniettate da /scripts/indizio.js,
               a posizione seedata dalla data del giorno (ADR-4). -->
          <p class="vw-map-note">
            Verga's World è un mondo di fantasia, la Vizzini che nasce quando un luogo incontra l'immaginazione.
            Non cercare strade esatte o confini precisi: segui i vicoli come indizi, entra nelle storie e lasciati guidare da ciò che ogni tappa custodisce.
          </p>
        </div>

        <!-- Box "Indizio di Verga" (75:1016) — stretto, sovrapposto top-right -->
        <aside id="indizio" class="vw-indizio" data-clue-panel aria-labelledby="indizio-title">
          <div class="vw-indizio__media">
            <div class="vw-indizio__frame">
              <img data-clue-image src={INDIZI[0].immagine} alt={INDIZI[0].nome} width="226" height="193" loading="lazy" decoding="async" />
            </div>
            <p class="vw-indizio__objlabel">
              <span class="obj-prefix">Oggetto del giorno: </span>
              <span class="obj-name" data-clue-object>{INDIZI[0].nome}</span>
            </p>
          </div>

          <span class="vw-pill vw-pill--teal">Missione giornaliera</span>
          <h2 id="indizio-title" class="vw-indizio__title">
            <img src="/immagini/figma-icona-missione.svg" alt="" width="44" height="44" />
            L'indizio di Verga
          </h2>
          <p class="vw-indizio__desc">
            Ogni giorno un oggetto si nasconde nella mappa di Vizzini. Osserva bene il borgo,
            clicca il punto giusto e scopri un piccolo indizio: è il primo passo del viaggio che continua al museo.
          </p>
          <p class="vw-indizio__countdown-label">Nuovo oggetto tra:</p>
          <!-- indizio.js scrive HH:MM:SS qui (selettore invariato, ADR-4) -->
          <p class="vw-indizio__countdown" data-clue-countdown aria-live="polite">--:--:--</p>
          <a class="vw-btn vw-btn--primary" href="#mappa">Cerca sulla mappa!</a>
        </aside>
      </div>
    </section>

    <script is:inline type="application/json" id="indizio-data" set:html={JSON.stringify(indizioData)}></script>

    <!-- PERSONAGGI (75:842 + 75:850) -->
    <section class="vw-section vw-characters" aria-labelledby="characters-title">
      <div class="vw-section__head">
        <span class="vw-pill vw-pill--teal">Personaggi</span>
        <h2 id="characters-title">Incontra i protagonisti</h2>
        <p>
          Ogni incontro lascia a Carletto qualcosa: un oggetto, una domanda, un modo nuovo di guardare Vizzini.
          C'è chi protegge senza fare rumore, chi custodisce un regno di cose rotte, chi disegna idee nella sabbia, chi litiga e poi sa fare pace.
        </p>
      </div>
      <div class="vw-wrap">
        <div class="vw-characters__rail" role="list">
          {PERSONAGGI.map((p) => (
            <article class="vw-char-card" role="listitem">
              <div class="vw-char-card__media">
                <img src={p.img} alt={p.nome} width="400" height="300" loading="lazy" decoding="async" />
              </div>
              <div class="vw-char-card__body">
                <h3>{p.nome}</h3>
                <p class="vw-char-card__role">{p.ruolo}</p>
                <p class="vw-char-card__desc">{p.desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA CODICE AVVENTURA (75:1005) -->
    <section class="vw-cta-code" aria-labelledby="cta-code-title">
      <div class="vw-cta-code__inner">
        <img class="vw-cta-code__icon" src="/immagini/figma-penna-calamaio.png" alt="" width="100" height="119" loading="lazy" />
        <h2 id="cta-code-title">Hai un codice avventura?</h2>
        <p class="vw-cta-code__lead">
          Il codice apre l'area riservata di Verga's World: video, attività interattive e materiali didattici
          per continuare l'esperienza durante la visita, a casa o in classe.
        </p>
        <p class="vw-cta-code__sub">
          Durante la visita al museo e anche dopo, i visitatori possono usare il codice avventura per sbloccare i contenuti video e fare giochi didattici.
        </p>
        <div class="vw-cta-code__actions">
          <a class="vw-btn vw-btn--gold" href="/avventura">Inserisci il codice</a>
          <a class="vw-btn vw-btn--ghost-light" href="/avventura">Scopri come funziona →</a>
        </div>
      </div>
    </section>

    <!-- SLIDER 7 STORIE (75:937) -->
    <section class="vw-stories" id="storie" data-stories aria-labelledby="stories-title">
      <div class="vw-stories__inner">
        <div class="vw-stories__head">
          <span class="vw-pill vw-pill--gold">Le tappe</span>
          <h2 id="stories-title">Sette storie, ti aspettano al museo</h2>
          <p>
            Ogni stanza racconta una tappa del viaggio di Carletto a Vizzini.
            Si parte da una camera grigia di Milano, si entra nei vicoli, nelle grotte, nelle piazze e sulle colline, fino al ritorno a casa.
            In ogni storia c'è un incontro, un oggetto da ricordare e una piccola scoperta da portare con sé.
          </p>
        </div>

        <div class="vw-stories__track" data-stories-track>
          {STORIE.map((s) => (
            <div class="vw-stories__slide" data-stories-slide>
              <article class="vw-story-card">
                <div class="vw-story-card__media">
                  <img src={s.immagine} alt={s.titolo} width="954" height="536" loading="lazy" decoding="async" />
                  <span class="vw-story-card__badge">{String(s.numero).padStart(2, "0")}</span>
                </div>
                <span class="vw-pill vw-pill--teal">Storia {s.numero} / 7</span>
                <h4>{s.titolo}</h4>
                <p class="vw-story-card__desc">{s.descrizione}</p>
                <a class="vw-btn vw-btn--primary" href="/avventura">Sblocca con il Codice Avventura</a>
              </article>
            </div>
          ))}
        </div>

        <div class="vw-stories__nav">
          <button type="button" class="vw-stories__arrow" data-stories-prev aria-label="Storia precedente">←</button>
          <div class="vw-stories__dots" role="tablist" aria-label="Seleziona storia">
            {STORIE.map((s, i) => (
              <button type="button" class="vw-stories__dot" data-stories-dot aria-current={i === 0 ? "true" : "false"} aria-label={`Vai alla tappa ${s.numero}: ${s.tappa}`}>{s.numero}</button>
            ))}
          </div>
          <button type="button" class="vw-stories__arrow" data-stories-next aria-label="Storia successiva">→</button>
        </div>
      </div>
    </section>

    <!-- PIANIFICA LA VISITA (75:896) -->
    <section class="vw-section vw-visit" id="visita" aria-labelledby="visit-title">
      <div class="vw-section__head">
        <span class="vw-pill vw-pill--teal">Museo R.I.V.I.V.I. - Borgo della Cunziria</span>
        <h2 id="visit-title">Pianifica la visita al museo</h2>
        <p>Scegli il percorso più adatto: una visita in famiglia o un'attività didattica pensata per la classe.</p>
      </div>
      <div class="vw-visit__cards">
        <article id="famiglie" class="vw-visit-card vw-visit-card--famiglie">
          <span class="vw-pill vw-pill--teal" style="background:#f4f8f2;">Famiglie</span>
          <h3>Vengo con la famiglia</h3>
          <p>Un percorso per bambini e adulti, con storie animate, indizi da cercare e attività semplici da fare insieme prima, durante e dopo la visita.</p>
          <a class="vw-btn vw-btn--primary" href="/famiglie">Prenota la visita</a>
        </article>
        <article id="scuole" class="vw-visit-card vw-visit-card--scuole">
          <span class="vw-pill vw-pill--teal">Scuole</span>
          <h3>Porto la mia classe</h3>
          <p>Materiali didattici, attività guidate e contenuti collegati alle stanze del museo, per preparare la visita e continuare il lavoro in classe.</p>
          <a class="vw-btn vw-btn--gold" href="/scuole">Organizza la gita</a>
        </article>
      </div>
    </section>
  </main>

  <!-- Modale "indizio trovato" (markup invariato per indizio.js) -->
  <div class="clue-success-modal" data-clue-success-modal aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="clue-success-heading">
    <div class="modal-overlay" data-modal-overlay></div>
    <div class="modal-panel" role="document">
      <button class="modal-close" data-clue-close aria-label="Chiudi">×</button>
      <div class="modal-icon" aria-hidden="true">✨</div>
      <div class="modal-content">
        <h3 id="clue-success-heading" data-clue-success-title>Bravo! Hai trovato l'indizio!</h3>
        <p data-clue-success-text>Esamina le lenti sulla mappa per scoprire l'indizio.</p>
      </div>
    </div>
  </div>

  <Footer />
</BaseLayout>
