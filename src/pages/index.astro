---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { INDIZI } from "../data/indizi.ts";
import { GAME_TIMEZONE } from "../config/game.ts";
import "../styles/styles.css"; // token + stili di Header/Footer condivisi
import "../styles/home.css"; // stili specifici della home (Figma 75-766)

// Build statica: la rotazione giornaliera va calcolata nel browser (ADR-4).
// Esportiamo l'intero pool + costanti al client; indizio.js seleziona l'oggetto
// del giorno al view-time. Fonte unica: src/data + src/config.
const indizioData = {
  indizi: INDIZI,
  timeZone: GAME_TIMEZONE,
};

// Le 7 tappe del museo (Figma 75:773–75:800). Sono etichette di presentazione
// della mappa, non un contratto condiviso: il nome della stanza del museo.
const TAPPE = [
  "Il Palazzo",
  "La Chiesa sulla collina",
  "La Giara",
  "L'Orto",
  "Il Salotto",
  "Il Villaggio",
  "Verga, il ritratto",
];

// Personaggi (Figma 75:850). Testi e immagini da testi-vergasworld.pdf
// (sezione "Personaggi"); immagini in /public/immagini/personaggi.
const PERSONAGGI = [
  { nome: "Carletto", ruolo: "Il viaggiatore", img: "/immagini/personaggi/carletto.jpg",
    desc: "Arriva da Milano con il vestito in ordine e la testa piena di noia. A Vizzini scopre che anche un sasso può contenere una storia intera." },
  { nome: "Caterina", ruolo: "La guida", img: "/immagini/personaggi/caterina.jpg",
    desc: "Conosce vicoli, cortili e scorci nascosti. Non spiega troppo: prende Carletto per mano e lo porta dove iniziano le avventure." },
  { nome: "Giovanni Verga", ruolo: "Il padrone di casa", img: "/immagini/personaggi/giovanni-verga.jpg",
    desc: "Nel suo palazzo gli adulti parlano e brindano. Fuori, intanto, le sue storie prendono vita tra i vicoli di Vizzini." },
  { nome: "Pina", ruolo: "La Lupa", img: "/immagini/personaggi/pina.jpg",
    desc: "Non ha bisogno di urlare per farsi ascoltare. Le basta uno sguardo per fermare i bulli e far capire a Carletto che il coraggio può essere silenzioso." },
  { nome: "Gesualdo", ruolo: "Il collezionista", img: "/immagini/personaggi/gesualdo.jpg",
    desc: "Vive in un cortile pieno di oggetti dimenticati. Difende il suo regno con diffidenza, finché un dono gli mostra che le cose diventano più belle quando si condividono." },
  { nome: "Rosso", ruolo: "Il genio incompreso", img: "/immagini/personaggi/rosso.jpg",
    desc: "Disegna nella sabbia canali, numeri e mappe. Ha mani sporche e capelli rossi, ma dentro la grotta accende la lezione più luminosa." },
  { nome: "Turiddu", ruolo: "Lo sfidante", img: "/immagini/personaggi/turiddu.jpg",
    desc: "Gioca alla morra con tutta la voce e tutta l'energia che ha. Per lui la sfida è vera, ma quando finisce, finisce davvero." },
  { nome: "Alfio", ruolo: "Il rivale leale", img: "/immagini/personaggi/alfio.jpg",
    desc: "Litiga forte, gioca fino all'ultimo punto e poi ride di cuore. Con Turiddu mostra a Carletto che fare pace è una forma di coraggio." },
  { nome: "I Malavoglia", ruolo: "La famiglia sulla barca", img: "/immagini/personaggi/i malavoglia.jpg",
    desc: "Remano su una barca ferma, in cima a una collina. Sognano il mare, ma sanno che il loro nespolo è il posto da cui partire e a cui tornare." },
  { nome: "Il padre di Carletto", ruolo: "L'adulto che capisce", img: "/immagini/personaggi/padre-di-carletto.jpg",
    desc: "All'inizio sembra lontano dal mondo dei bambini. Alla fine, davanti al sasso di Pina, intuisce che Carletto non è solo sporco di polvere: è pieno di storie." },
];

// Slide dello slider storie (Figma 75:946). Copy autorevole da testi-vergasworld.pdf
// (titoli carosello + testi delle 7 storie). Le immagini riusano asset esistenti
// in /public/immagini (il PDF non fornisce le immagini dello slider).
const STORIE = [
  {
    numero: 1,
    titolo: "L'inizio del viaggio",
    immagine: "/immagini/palazzo di verga.jpg",
    descrizione:
      "Carletto è tornato a Milano, ma ha ancora Vizzini nella testa. Nella valigia trova un sasso colorato e il ricordo si apre: Palazzo Verga, una tavola piena di adulti, un panino rubato sotto la tovaglia e Caterina, pronta a portarlo fuori, dove comincia davvero l'avventura.",
  },
  {
    numero: 2,
    titolo: "L'incontro con la Lupa",
    immagine: "/immagini/figma-piazza-cunziria.png",
    descrizione:
      "Nei vicoli della Cunziria, Carletto si sente fuori posto. Due ragazzi più grandi lo prendono in giro e lui ha paura. Poi arriva Pina, che tutti chiamano la Lupa: non urla, non colpisce, ma protegge con uno sguardo fermo. Prima di andare via, gli lascia un sasso colorato.",
  },
  {
    numero: 3,
    titolo: "L'incontro con Gesualdo",
    immagine: "/immagini/incontro con gesualdo.jpg",
    descrizione:
      "Carletto e Caterina trovano una montagna di oggetti dimenticati. In cima c'è Gesualdo, seduto come un piccolo re, con il suo soldatino stretto al petto. Non vuole far passare nessuno. Poi Carletto gli dona la bussola: la montagna smette di essere un muro e diventa un passaggio.",
  },
  {
    numero: 4,
    titolo: "L'incontro con Rosso",
    immagine: "/immagini/malpelo.jpg",
    descrizione:
      "Caterina porta Carletto dentro una grotta scavata nella roccia. All'inizio lui vede solo il buio, la polvere e un bambino dai capelli rossi. Poi guarda meglio: sulla sabbia ci sono mappe, numeri e progetti per portare l'acqua fino al paese. Rosso gli mostra che il talento può nascondersi dove nessuno si ferma a guardare.",
  },
  {
    numero: 5,
    titolo: "L'incontro con Turiddu e Alfio",
    immagine: "/immagini/vizzini.jpg",
    descrizione:
      "Nella piazza di Vizzini, due bambini gridano e gesticolano sotto un grande albero. Carletto pensa che stiano litigando, ma Caterina ha già capito: Turiddu e Alfio stanno giocando alla Morra. La sfida è accesa, le regole sono importanti. Quando la partita finisce, finiscono anche i rancori: si ride, si fa pace e si dividono i cannoli.",
  },
  {
    numero: 6,
    titolo: "L'incontro con i Malavoglia",
    immagine: "/immagini/malavoglia.jpg",
    descrizione:
      "Fuori dal paese, su una collina, Carletto vede una cosa impossibile: una barca sull'erba, lontana dal mare. Dentro ci sono bambini che remano e immaginano di navigare. Accanto a loro cresce un nespolo, con le radici nella terra. Carletto capisce che si può sognare di partire e, allo stesso tempo, avere un posto a cui tornare.",
  },
  {
    numero: 7,
    titolo: "Il ritorno di Carletto",
    immagine: "/immagini/vizzini.jpg",
    descrizione:
      "Il sole tramonta su Vizzini e Carletto torna a Palazzo Verga con i vestiti sporchi, i capelli in disordine e il sasso di Pina in mano. Non racconta subito tutto: appoggia il sasso sul tavolo, tra bicchieri e posate eleganti. Dentro quell'oggetto ci sono tutti gli incontri del viaggio. Quando torna a Milano, la stanza è la stessa, ma lui guarda il mondo con occhi diversi.",
  },
];

// 7 pin dei luoghi sulla mappa (Figma 75:801, testi da testi-vergasworld.pdf).
// Distinti dalle 3 lenti "indizio" (iniettate a caso da indizio.js).
// leftPct/topPct = posizione sulla mappa stimata dal layout Figma.
// L'abbinamento nome↔posizione è modificabile qui senza toccare il markup.
const LUOGHI = [
  {
    nome: "Palazzo Verga",
    leftPct: 41.3,
    topPct: 58.7,
    testo:
      "Qui Carletto incontra Caterina, nascosta sotto il tavolo con un panino in mano. È il primo passo fuori dal mondo degli adulti: da questo palazzo comincia la corsa nei vicoli di Vizzini.",
  },
  {
    nome: "I vicoli della Cunziria",
    leftPct: 59.9,
    topPct: 74.9,
    testo:
      "Tra queste strade strette Carletto si sente fuori posto e ha paura. Poi arriva Pina, che tutti chiamano la Lupa: non urla, non colpisce, ma protegge con uno sguardo fermo.",
  },
  {
    nome: "Il vicolo degli oggetti",
    leftPct: 46.6,
    topPct: 48.4,
    testo:
      "In questo vicolo Gesualdo custodisce il suo regno: ruote, bauli, corde, legni e cose dimenticate. Per lui sono un tesoro. Quando Carletto gli dona la bussola, la montagna smette di essere un muro e diventa un passaggio.",
  },
  {
    nome: "La grotta di Rosso",
    leftPct: 15.1,
    topPct: 64.6,
    testo:
      "Fuori c'è il sole, dentro sembra notte. In fondo alla grotta Carletto trova Rosso, con i capelli rossi e le mani sporche di terra. Poi guarda meglio: nella sabbia ci sono mappe, numeri e un progetto per portare l'acqua al paese.",
  },
  {
    nome: "La piazza della Morra",
    leftPct: 14.4,
    topPct: 41.5,
    testo:
      "Sotto il grande albero, Turiddu e Alfio gridano, gesticolano e sembrano litigare. In realtà stanno giocando alla Morra. La sfida è forte, ma ha regole precise: quando finisce, si ride, si fa pace e si dividono i cannoli.",
  },
  {
    nome: "La collina del nespolo",
    leftPct: 26.3,
    topPct: 36.5,
    testo:
      "Qui Carletto trova una barca sull'erba, lontana dal mare. I bambini Malavoglia remano e immaginano di partire, ma accanto a loro c'è il nespolo: il segno delle radici, della casa e del posto a cui tornare.",
  },
  {
    nome: "Il panorama del ritorno",
    leftPct: 47.7,
    topPct: 20.5,
    testo:
      "Al tramonto, Carletto guarda Vizzini con occhi diversi. Ha i vestiti sporchi, il sasso di Pina in mano e la testa piena di incontri. Il viaggio sta finendo, ma le storie restano con lui.",
  },
];
---

<BaseLayout
  title="Verga's World: storie e giochi al Museo R.I.VI.VI."
  description="Scopri Verga's World a Vizzini: 7 storie animate, indizi, personaggi e attività per vivere il Museo R.I.VI.VI. con famiglie e scuole."
  fonts="none"
  scripts={[
    { src: "/scripts/indizio.js", defer: true },
    { src: "/scripts/home-slider.js", defer: true },
  ]}
>
  <Header />

  <main id="main-content" class="vw-home">
    <!-- HERO (75:928) -->
    <section class="vw-hero" aria-labelledby="hero-title">
      <div class="vw-hero__intro">
        <h1 id="hero-title" class="vw-hero__title">
          <img class="vw-hero__logo" src="/immagini/figma-logo-vergas-world.png" alt="Verga's World" width="606" height="243" fetchpriority="high" />
        </h1>
        <p class="vw-hero__lead">
          Esplora Vizzini attraverso <strong>7 storie animate, indizi nascosti</strong>
          e attività da sbloccare durante la visita al museo R.I.V.I.V.I.
        </p>
        <div class="vw-hero__actions">
          <a class="vw-btn vw-btn--primary" href="/#visita">Prenota la visita</a>
          <a class="vw-btn vw-btn--ghost" href="/avventura">Ho un codice avventura →</a>
        </div>
      </div>
    </section>

    <!-- MAPPA + BOX INDIZIO (75:769 + 75:1016) -->
    <section class="vw-map-section" id="mappa" aria-labelledby="mappa-title">
      <h2 id="mappa-title" hidden>Mappa illustrata di Vizzini</h2>

      <!-- Tab tappe in una riga in cima alla mappa (75:773–75:800) -->
      <div class="vw-tappe" role="list" aria-label="Le tappe del museo">
        {TAPPE.map((nome, i) => (
          <span class="vw-tappa" role="listitem">
            <span class="vw-tappa__num">{i + 1}</span>
            <span>{nome}</span>
          </span>
        ))}
      </div>

      <!-- La mappa è una illustrazione panoramica grande, a tutta larghezza.
           Il box indizio le galleggia sopra l'angolo top-right (desktop). -->
      <div class="vw-map-overlay">
        <div class="vw-map-stage" data-clue-map aria-label="Mappa illustrata interattiva di Vizzini">
          <img class="vw-map-stage__img" src="/immagini/mappa-vizzini.png" alt="Mappa illustrata del paese di Vizzini con le tappe del museo" decoding="async" />

          <!-- I 7 pin dei luoghi (statici). Aprono la modale con titolo + testo.
               L'oggetto del giorno si nasconde nel pin del suo luogo: indizio.js
               marca quel pin con data-found-* e la modale rivela l'oggetto. -->
          {LUOGHI.map((l, i) => (
            <button
              type="button"
              class="vw-map-pointer"
              data-luogo
              data-titolo={l.nome}
              data-testo={l.testo}
              style={`left:${l.leftPct}%;top:${l.topPct}%`}
              aria-haspopup="dialog"
            ><span class="vw-map-pointer__num" aria-hidden="true">{i + 1}</span><span class="vw-map-pointer__label">{l.nome}</span></button>
          ))}

          <p class="vw-map-note">
            Verga's World è un mondo di fantasia, la Vizzini che nasce quando un luogo incontra l'immaginazione.
            Non cercare strade esatte o confini precisi: segui i vicoli come indizi, entra nelle storie e lasciati guidare da ciò che ogni tappa custodisce.
          </p>
        </div>

        <!-- Box "Indizio di Verga" (75:1016) — stretto, sovrapposto top-right -->
        <aside id="indizio" class="vw-indizio" data-clue-panel aria-labelledby="indizio-title">
          <div class="vw-indizio__media">
            <div class="vw-indizio__frame">
              <img data-clue-image src={INDIZI[0].immagine} alt={INDIZI[0].nome} width="226" height="193" loading="lazy" decoding="async" />
            </div>
            <p class="vw-indizio__objlabel">
              <span class="obj-prefix">Oggetto del giorno: </span>
              <span class="obj-name" data-clue-object>{INDIZI[0].nome}</span>
            </p>
          </div>

          <span class="vw-pill vw-pill--teal">Missione giornaliera</span>
          <h2 id="indizio-title" class="vw-indizio__title">
            <img src="/immagini/figma-icona-missione.svg" alt="" width="44" height="44" />
            L'indizio di Verga
          </h2>
          <p class="vw-indizio__desc">
            Ogni giorno un oggetto si nasconde nella mappa di Vizzini. Osserva bene il borgo,
            clicca il punto giusto e scopri un piccolo indizio: è il primo passo del viaggio che continua al museo.
          </p>
          <p class="vw-indizio__countdown-label">Nuovo oggetto tra:</p>
          <!-- indizio.js scrive HH:MM:SS qui (selettore invariato, ADR-4) -->
          <p class="vw-indizio__countdown" data-clue-countdown aria-live="polite">--:--:--</p>
          <a class="vw-btn vw-btn--primary" href="#mappa">Cerca sulla mappa!</a>
        </aside>
      </div>
    </section>

    <script is:inline type="application/json" id="indizio-data" set:html={JSON.stringify(indizioData)}></script>

    <!-- CTA CODICE AVVENTURA (75:1005) -->
    <section class="vw-cta-code" aria-labelledby="cta-code-title">
      <!-- Sfondo illustrato sotto al gradiente teal (Figma 40:41, opacità 20%) -->
      <img class="vw-cta-code__bg" src="/immagini/figma-codice-avventura-bg.jpg" alt="" aria-hidden="true" loading="lazy" decoding="async" />
      <div class="vw-cta-code__inner">
        <img class="vw-cta-code__icon" src="/immagini/figma-penna-calamaio.png" alt="" width="100" height="119" loading="lazy" />
        <h2 id="cta-code-title">Hai un codice avventura?</h2>
        <p class="vw-cta-code__lead">
          Il codice apre l'area riservata di Verga's World: video, attività interattive e materiali didattici
          per continuare l'esperienza durante la visita, a casa o in classe.
        </p>
        <p class="vw-cta-code__sub">
          Durante la visita al museo e anche dopo, i visitatori possono usare il codice avventura per sbloccare i contenuti video e fare giochi didattici.
        </p>
        <div class="vw-cta-code__actions">
          <a class="vw-btn vw-btn--gold" href="/avventura">Inserisci il codice</a>
          <a class="vw-btn vw-btn--ghost-light" href="/avventura">Scopri come funziona →</a>
        </div>
      </div>
    </section>

    <!-- PERSONAGGI (75:842 + 75:850) -->
    <section class="vw-section vw-characters" aria-labelledby="characters-title">
      <div class="vw-section__head">
        <span class="vw-pill vw-pill--teal">Personaggi</span>
        <h2 id="characters-title">Incontra i protagonisti</h2>
        <p>
          Ogni incontro lascia a Carletto qualcosa: un oggetto, una domanda, un modo nuovo di guardare Vizzini.
          C'è chi protegge senza fare rumore, chi custodisce un regno di cose rotte, chi disegna idee nella sabbia, chi litiga e poi sa fare pace.
        </p>
      </div>
      <div class="vw-wrap">
        <div class="vw-characters__rail" role="list">
          {PERSONAGGI.map((p) => (
            <article class="vw-char-card" role="listitem">
              <div class="vw-char-card__media">
                <img src={p.img} alt={p.nome} width="400" height="300" loading="lazy" decoding="async" />
              </div>
              <div class="vw-char-card__body">
                <h3>{p.nome}</h3>
                <p class="vw-char-card__role">{p.ruolo}</p>
                <p class="vw-char-card__desc">{p.desc}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- SLIDER 7 STORIE (75:937) -->
    <section class="vw-stories" id="storie" data-stories aria-labelledby="stories-title">
      <div class="vw-stories__inner">
        <div class="vw-stories__head">
          <span class="vw-pill vw-pill--gold">Le tappe</span>
          <h2 id="stories-title">Sette storie ti aspettano al museo</h2>
          <p>
            Ogni stanza racconta una tappa del viaggio di Carletto a Vizzini.
            Si parte da una camera grigia di Milano, si entra nei vicoli, nelle grotte, nelle piazze e sulle colline, fino al ritorno a casa.
            In ogni storia c'è un incontro, un oggetto da ricordare e una piccola scoperta da portare con sé.
          </p>
        </div>

        <div class="vw-stories__track" data-stories-track>
          {STORIE.map((s) => {
            // 4 immagini per storia in /public/immagini/storie/storia-N/ (immagine-1..4).
            // immagine-1 = principale; le altre 3 = thumbnail cliccabili.
            const imgs = [1, 2, 3, 4].map((n) => `/immagini/storie/storia-${s.numero}/immagine-${n}.jpg`);
            return (
            <div class="vw-stories__slide" data-stories-slide>
              <article class="vw-story-card">
                <div class="vw-story-card__gallery">
                  <div class="vw-story-card__media">
                    <img data-story-main src={imgs[0]} alt={s.titolo} width="954" height="536" loading="lazy" decoding="async" />
                    <span class="vw-story-card__badge">{String(s.numero).padStart(2, "0")}</span>
                  </div>
                  <div class="vw-story-card__thumbs" role="group" aria-label={`Altre immagini di ${s.titolo}`}>
                    {imgs.slice(1).map((src, i) => (
                      <button type="button" class="vw-story-card__thumb" data-story-thumb data-full={src} aria-label={`Mostra immagine ${i + 2} di ${s.titolo}`}>
                        <img src={src} alt="" width="120" height="68" loading="lazy" decoding="async" />
                      </button>
                    ))}
                  </div>
                </div>
                <span class="vw-pill vw-pill--teal">Storia {s.numero} / 7</span>
                <h3>{s.titolo}</h3>
                <p class="vw-story-card__desc">{s.descrizione}</p>
                <a class="vw-btn vw-btn--primary" href="/avventura">Sblocca con il Codice Avventura</a>
              </article>
            </div>
            );
          })}
        </div>

        <div class="vw-stories__nav">
          <button type="button" class="vw-stories__arrow" data-stories-prev aria-label="Storia precedente">←</button>
          <div class="vw-stories__dots" role="tablist" aria-label="Seleziona storia">
            {STORIE.map((s, i) => (
              <button type="button" class="vw-stories__dot" data-stories-dot aria-current={i === 0 ? "true" : "false"} aria-label={`Vai alla storia ${s.numero}: ${s.titolo}`}>{s.numero}</button>
            ))}
          </div>
          <button type="button" class="vw-stories__arrow" data-stories-next aria-label="Storia successiva">→</button>
        </div>
      </div>
    </section>

    <!-- PIANIFICA LA VISITA (75:896) -->
    <section class="vw-section vw-visit" id="visita" aria-labelledby="visit-title">
      <div class="vw-section__head">
        <span class="vw-pill vw-pill--teal">Museo R.I.V.I.V.I. - Borgo della Cunziria</span>
        <h2 id="visit-title">Pianifica la visita al museo</h2>
        <p>Scegli il percorso più adatto: una visita in famiglia o un'attività didattica pensata per la classe.</p>
      </div>
      <div class="vw-visit__cards">
        <article id="famiglie" class="vw-visit-card vw-visit-card--famiglie">
          <span class="vw-pill vw-pill--teal" style="background:#f4f8f2;">Famiglie</span>
          <h3>Vengo con la famiglia</h3>
          <p>Un percorso per bambini e adulti, con storie animate, indizi da cercare e attività semplici da fare insieme prima, durante e dopo la visita.</p>
          <a class="vw-btn vw-btn--primary" href="/visite-in-famiglia">Prenota la visita</a>
        </article>
        <article id="scuole" class="vw-visit-card vw-visit-card--scuole">
          <span class="vw-pill vw-pill--teal">Scuole</span>
          <h3>Porto la mia classe</h3>
          <p>Materiali didattici, attività guidate e contenuti collegati alle stanze del museo, per preparare la visita e continuare il lavoro in classe.</p>
          <a class="vw-btn vw-btn--gold" href="/visite-scolastiche">Organizza la gita</a>
        </article>
      </div>
    </section>
  </main>

  <!-- Modale dei pin "luogo" (riusa lo stile di .clue-success-modal).
       Se il luogo nasconde l'oggetto del giorno, indizio.js marca il pin con
       data-found-* e qui appare il blocco "oggetto trovato". -->
  <div class="clue-success-modal vw-luogo-modal" data-luogo-modal aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="luogo-modal-title">
    <div class="modal-overlay" data-luogo-overlay></div>
    <div class="modal-panel" role="document">
      <button class="modal-close" data-luogo-close aria-label="Chiudi">×</button>
      <div class="modal-content">
        <h3 id="luogo-modal-title" data-luogo-title></h3>
        <p data-luogo-text></p>

        <div class="vw-luogo-found" data-luogo-found hidden>
          <div class="vw-luogo-found__frame">
            <img data-luogo-found-img alt="" width="120" height="102" loading="lazy" decoding="async" />
          </div>
          <p class="vw-luogo-found__congrats">✨ Complimenti, hai trovato l'oggetto del giorno!</p>
          <p class="vw-luogo-found__text" data-luogo-found-text></p>
        </div>

        <a class="vw-btn vw-btn--primary" href="/#storie">Scopri la storia</a>
      </div>
    </div>
  </div>

  <script>
    // Slider storie: click su una thumbnail → cambia l'immagine principale della slide.
    document.querySelectorAll<HTMLButtonElement>("[data-story-thumb]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const media = btn.closest(".vw-story-card__gallery");
        const main = media?.querySelector<HTMLImageElement>("[data-story-main]");
        const full = btn.dataset.full;
        if (main && full) main.src = full;
        media?.querySelectorAll("[data-story-thumb]").forEach((b) =>
          b.setAttribute("aria-current", b === btn ? "true" : "false")
        );
      });
    });
  </script>

  <script>
    // Apertura/chiusura modale dei pin "luogo" sulla mappa.
    const modal = document.querySelector("[data-luogo-modal]");
    if (modal) {
      const m = modal;
      const titleEl = m.querySelector("[data-luogo-title]");
      const textEl = m.querySelector("[data-luogo-text]");
      const closeBtn = m.querySelector("[data-luogo-close]");
      const overlay = m.querySelector("[data-luogo-overlay]");
      const found = m.querySelector("[data-luogo-found]");
      const foundImg = m.querySelector("[data-luogo-found-img]") as HTMLImageElement | null;
      const foundText = m.querySelector("[data-luogo-found-text]");
      let lastFocused: HTMLElement | null = null;

      const panel = m.querySelector(".modal-panel") as HTMLElement | null;

      // Elementi focalizzabili visibili nel pannello (per il focus trap, WCAG 2.1.2).
      const focusables = (): HTMLElement[] => {
        if (!panel) return [];
        return Array.from(
          panel.querySelectorAll<HTMLElement>(
            'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
          )
        ).filter((el) => el.offsetParent !== null);
      };

      const close = () => {
        m.setAttribute("aria-hidden", "true");
        if (lastFocused) lastFocused.focus();
      };

      document.querySelectorAll("[data-luogo]").forEach((pin) => {
        pin.addEventListener("click", () => {
          const p = pin as HTMLElement;
          lastFocused = p;
          if (titleEl) titleEl.textContent = p.getAttribute("data-titolo");
          if (textEl) textEl.textContent = p.getAttribute("data-testo");

          // Oggetto del giorno nascosto qui? (indizio.js ha marcato il pin)
          const name = p.dataset.foundName;
          if (found && name && foundImg && foundText) {
            foundImg.src = p.dataset.foundImage || "";
            foundImg.alt = name;
            foundText.textContent = p.dataset.foundText || "";
            (found as HTMLElement).hidden = false;
          } else if (found) {
            (found as HTMLElement).hidden = true;
          }

          m.setAttribute("aria-hidden", "false");
          if (closeBtn instanceof HTMLElement) closeBtn.focus();
        });
      });

      closeBtn?.addEventListener("click", close);
      overlay?.addEventListener("click", close);
      document.addEventListener("keydown", (e) => {
        if (m.getAttribute("aria-hidden") !== "false") return;
        if (e.key === "Escape") {
          close();
          return;
        }
        // Focus trap: Tab/Shift+Tab restano dentro il pannello (WCAG 2.1.2).
        if (e.key === "Tab") {
          const items = focusables();
          if (items.length === 0) return;
          const first = items[0];
          const last = items[items.length - 1];
          const active = document.activeElement as HTMLElement | null;
          if (e.shiftKey && (active === first || !panel?.contains(active))) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && active === last) {
            e.preventDefault();
            first.focus();
          }
        }
      });
    }
  </script>

  <Footer />
</BaseLayout>
