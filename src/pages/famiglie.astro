---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/styles.css";

---

<BaseLayout
  title="Vengo con la famiglia | Verga's World"
  fonts="none"
  scripts={[{ src: "/scripts/app.js" }]}
>
  <header class="topbar">
        <a class="brand" href="/" aria-label="Verga's World home">
          <span class="brand-mark">VW</span>
          <span>
            <strong>Verga's World</strong>
            <small>Casa Verga, Vizzini</small>
          </span>
        </a>
        <img decoding="async" loading="lazy" class="header-project-logo" src="/immagini/Logo di Progetto Borgo cunziria.jpg" alt="Logo progetto Borgo della Cunziria" />
        <nav aria-label="Navigazione pagina">
          <a href="/">Home</a>
          <a href="/scuole">Scuole</a>
        </nav>
        <button class="menu-toggle" type="button" data-menu-toggle aria-expanded="false" aria-controls="kid-menu" aria-label="Apri menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <div id="kid-menu" class="kid-menu" data-kid-menu hidden>
          <a href="/">Home</a>
          <a href="/famiglie">Vengo con la famiglia</a>
          <a href="/scuole">Porto la mia classe</a>
          <a href="/borgo-cunziria">Borgo Cunziria</a>
          <a class="nav-cta" href="/avventura">Ho il Codice Avventura!</a>
        </div>
      </header>

      <main id="main-content">
        <section class="section-heading" style="padding: 36px clamp(18px, 5vw, 64px); text-align: center;">
          <p class="kicker">Visite in famiglia</p>
          <h1>Pianifica la tua visita con i bambini</h1>
          <p>Una proposta per le famiglie con bambini, con percorsi interattivi, attività scoperta e consigli pratici per una giornata al museo.</p>
        </section>

        <section class="card" style="margin: 0 auto 32px auto; max-width: 980px; overflow: hidden;">
          <img decoding="async" loading="lazy" src="/immagini/carletto.jpg" alt="Bambino e famiglia al museo" style="width:100%; height:360px; object-fit:cover; display:block;" />
          <div class="card-body">
            <h2>Percorso famiglia</h2>
            <p>Scopri come trasformare la visita in un’esperienza giocosa per i più piccoli, con momenti dedicati alla scoperta dei personaggi e dei luoghi di Verga.</p>
            <ul>
              <li>Attività pensate per bambini 6-12 anni</li>
              <li>Suggerimenti per rendere la visita coinvolgente e divertente</li>
              <li>Spunti per giochi, racconti e laboratori in museo</li>
            </ul>
          </div>
        </section>

        <section class="card" style="margin: 0 auto 32px auto; max-width: 980px; overflow: hidden;">
          <div class="card-body">
            <h2>Come arrivare e cosa portare</h2>
            <p>Informazioni utili per l’organizzazione pratica della giornata: orari consigliati, indicazioni su accesso e fruizione, e la proposta del percorso narrativo per la famiglia.</p>
            <a class="button primary" href="/">Torna alla homepage</a>
          </div>
        </section>
      </main>


</BaseLayout>
