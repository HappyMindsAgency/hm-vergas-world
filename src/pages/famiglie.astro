---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/styles.css";

const body = "<header class=\"topbar\">\r\n      <a class=\"brand\" href=\"/\" aria-label=\"Verga's World home\">\r\n        <span class=\"brand-mark\">VW</span>\r\n        <span>\r\n          <strong>Verga's World</strong>\r\n          <small>Casa Verga, Vizzini</small>\r\n        </span>\r\n      </a>\r\n      <img decoding=\"async\" loading=\"lazy\" class=\"header-project-logo\" src=\"/immagini/Logo di Progetto Borgo cunziria.jpg\" alt=\"Logo progetto Borgo della Cunziria\" />\r\n      <nav aria-label=\"Navigazione pagina\">\r\n        <a href=\"/\">Home</a>\r\n        <a href=\"/scuole\">Scuole</a>\r\n      </nav>\r\n      <button class=\"menu-toggle\" type=\"button\" data-menu-toggle aria-expanded=\"false\" aria-controls=\"kid-menu\" aria-label=\"Apri menu\">\r\n        <span></span>\r\n        <span></span>\r\n        <span></span>\r\n      </button>\r\n      <div id=\"kid-menu\" class=\"kid-menu\" data-kid-menu hidden>\r\n        <a href=\"/\">Home</a>\r\n        <a href=\"/famiglie\">Vengo con la famiglia</a>\r\n        <a href=\"/scuole\">Porto la mia classe</a>\r\n        <a href=\"/borgo-cunziria\">Borgo Cunziria</a>\r\n        <a class=\"nav-cta\" href=\"/avventura\">Ho il Codice Avventura!</a>\r\n      </div>\r\n    </header>\r\n\r\n    <main id=\"main-content\">\r\n      <section class=\"section-heading\" style=\"padding: 36px clamp(18px, 5vw, 64px); text-align: center;\">\r\n        <p class=\"kicker\">Visite in famiglia</p>\r\n        <h1>Pianifica la tua visita con i bambini</h1>\r\n        <p>Una proposta per le famiglie con bambini, con percorsi interattivi, attività scoperta e consigli pratici per una giornata al museo.</p>\r\n      </section>\r\n\r\n      <section class=\"card\" style=\"margin: 0 auto 32px auto; max-width: 980px; overflow: hidden;\">\r\n        <img decoding=\"async\" loading=\"lazy\" src=\"/immagini/carletto.jpg\" alt=\"Bambino e famiglia al museo\" style=\"width:100%; height:360px; object-fit:cover; display:block;\" />\r\n        <div class=\"card-body\">\r\n          <h2>Percorso famiglia</h2>\r\n          <p>Scopri come trasformare la visita in un’esperienza giocosa per i più piccoli, con momenti dedicati alla scoperta dei personaggi e dei luoghi di Verga.</p>\r\n          <ul>\r\n            <li>Attività pensate per bambini 6-12 anni</li>\r\n            <li>Suggerimenti per rendere la visita coinvolgente e divertente</li>\r\n            <li>Spunti per giochi, racconti e laboratori in museo</li>\r\n          </ul>\r\n        </div>\r\n      </section>\r\n\r\n      <section class=\"card\" style=\"margin: 0 auto 32px auto; max-width: 980px; overflow: hidden;\">\r\n        <div class=\"card-body\">\r\n          <h2>Come arrivare e cosa portare</h2>\r\n          <p>Informazioni utili per l’organizzazione pratica della giornata: orari consigliati, indicazioni su accesso e fruizione, e la proposta del percorso narrativo per la famiglia.</p>\r\n          <a class=\"button primary\" href=\"/\">Torna alla homepage</a>\r\n        </div>\r\n      </section>\r\n    </main>";
---

<BaseLayout
  title="Vengo con la famiglia | Verga's World"
  fonts="none"
  scripts={[{ src: "/scripts/app.js" }]}
>
  <Fragment set:html={body} />

</BaseLayout>
