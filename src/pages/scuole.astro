---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/styles.css";

const body = "<header class=\"topbar\">\r\n      <a class=\"brand\" href=\"/\" aria-label=\"Verga's World home\">\r\n        <span class=\"brand-mark\">VW</span>\r\n        <span>\r\n          <strong>Verga's World</strong>\r\n          <small>Casa Verga, Vizzini</small>\r\n        </span>\r\n      </a>\r\n      <img decoding=\"async\" loading=\"lazy\" class=\"header-project-logo\" src=\"/immagini/Logo di Progetto Borgo cunziria.jpg\" alt=\"Logo progetto Borgo della Cunziria\" />\r\n      <nav aria-label=\"Navigazione pagina\">\r\n        <a href=\"/\">Home</a>\r\n        <a href=\"/famiglie\">Famiglie</a>\r\n      </nav>\r\n      <button class=\"menu-toggle\" type=\"button\" data-menu-toggle aria-expanded=\"false\" aria-controls=\"kid-menu\" aria-label=\"Apri menu\">\r\n        <span></span>\r\n        <span></span>\r\n        <span></span>\r\n      </button>\r\n      <div id=\"kid-menu\" class=\"kid-menu\" data-kid-menu hidden>\r\n        <a href=\"/\">Home</a>\r\n        <a href=\"/famiglie\">Vengo con la famiglia</a>\r\n        <a href=\"/scuole\">Porto la mia classe</a>\r\n        <a href=\"/borgo-cunziria\">Borgo Cunziria</a>\r\n        <a class=\"nav-cta\" href=\"/avventura\">Ho il Codice Avventura!</a>\r\n      </div>\r\n    </header>\r\n\r\n    <main id=\"main-content\">\r\n      <section class=\"section-heading\" style=\"padding: 36px clamp(18px, 5vw, 64px); text-align: center;\">\r\n        <p class=\"kicker\">Visite scolastiche</p>\r\n        <h1>Organizza la visita con la tua classe</h1>\r\n        <p>Trova materiali, percorsi guidati e informazioni per rendere la tua esperienza didattica al museo coinvolgente e semplice da preparare.</p>\r\n      </section>\r\n\r\n      <section class=\"card\" style=\"margin: 0 auto 32px auto; max-width: 980px; overflow: hidden;\">\r\n        <img decoding=\"async\" loading=\"lazy\" src=\"/immagini/palazzo di verga.jpg\" alt=\"Ingresso al museo Casa Verga\" style=\"width:100%; height:360px; object-fit:cover; display:block;\" />\r\n        <div class=\"card-body\">\r\n          <h2>Percorso didattico per le classi</h2>\r\n          <p>Un itinerario pensato per le scuole con attività in museo suddivise per tema, supporti digitali e materiali da usare prima, durante e dopo la visita.</p>\r\n          <ul>\r\n            <li>Proposta di percorso in 7 tappe nelle storie del museo</li>\r\n            <li>Attività di gruppo su casa, lavoro e comunità</li>\r\n            <li>Guida per insegnanti e suggerimenti per la preparazione</li>\r\n          </ul>\r\n        </div>\r\n      </section>\r\n\r\n      <section class=\"card\" style=\"margin: 0 auto 32px auto; max-width: 980px; overflow: hidden;\">\r\n        <div class=\"card-body\">\r\n          <h2>Come organizzare la visita</h2>\r\n          <p>Scopri i dettagli pratici per la prenotazione, l'accoglienza in museo, i tempi consigliati e la proposta di percorso per le scuole primarie.</p>\r\n          <p>La proposta include materiali didattici, esercizi di osservazione e suggerimenti per prolungare l’esperienza in classe.</p>\r\n          <a class=\"button primary\" href=\"/\">Torna alla homepage</a>\r\n        </div>\r\n      </section>\r\n    </main>";
---

<BaseLayout
  title="Porto la mia classe | Verga's World"
  fonts="none"
  scripts={[{ src: "/scripts/app.js" }]}
>
  <Fragment set:html={body} />

</BaseLayout>
