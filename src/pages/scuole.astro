---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/styles.css";

---

<BaseLayout
  title="Porto la mia classe | Verga's World"
  fonts="none"
  scripts={[{ src: "/scripts/app.js" }]}
>
  <header class="topbar">
        <a class="brand" href="/" aria-label="Verga's World home">
          <span class="brand-mark">VW</span>
          <span>
            <strong>Verga's World</strong>
            <small>Casa Verga, Vizzini</small>
          </span>
        </a>
        <img decoding="async" loading="lazy" class="header-project-logo" src="/immagini/Logo di Progetto Borgo cunziria.jpg" alt="Logo progetto Borgo della Cunziria" />
        <nav aria-label="Navigazione pagina">
          <a href="/">Home</a>
          <a href="/famiglie">Famiglie</a>
        </nav>
        <button class="menu-toggle" type="button" data-menu-toggle aria-expanded="false" aria-controls="kid-menu" aria-label="Apri menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <div id="kid-menu" class="kid-menu" data-kid-menu hidden>
          <a href="/">Home</a>
          <a href="/famiglie">Vengo con la famiglia</a>
          <a href="/scuole">Porto la mia classe</a>
          <a href="/borgo-cunziria">Borgo Cunziria</a>
          <a class="nav-cta" href="/avventura">Ho il Codice Avventura!</a>
        </div>
      </header>

      <main id="main-content">
        <section class="section-heading" style="padding: 36px clamp(18px, 5vw, 64px); text-align: center;">
          <p class="kicker">Visite scolastiche</p>
          <h1>Organizza la visita con la tua classe</h1>
          <p>Trova materiali, percorsi guidati e informazioni per rendere la tua esperienza didattica al museo coinvolgente e semplice da preparare.</p>
        </section>

        <section class="card" style="margin: 0 auto 32px auto; max-width: 980px; overflow: hidden;">
          <img decoding="async" loading="lazy" src="/immagini/palazzo di verga.jpg" alt="Ingresso al museo Casa Verga" style="width:100%; height:360px; object-fit:cover; display:block;" />
          <div class="card-body">
            <h2>Percorso didattico per le classi</h2>
            <p>Un itinerario pensato per le scuole con attività in museo suddivise per tema, supporti digitali e materiali da usare prima, durante e dopo la visita.</p>
            <ul>
              <li>Proposta di percorso in 7 tappe nelle storie del museo</li>
              <li>Attività di gruppo su casa, lavoro e comunità</li>
              <li>Guida per insegnanti e suggerimenti per la preparazione</li>
            </ul>
          </div>
        </section>

        <section class="card" style="margin: 0 auto 32px auto; max-width: 980px; overflow: hidden;">
          <div class="card-body">
            <h2>Come organizzare la visita</h2>
            <p>Scopri i dettagli pratici per la prenotazione, l'accoglienza in museo, i tempi consigliati e la proposta di percorso per le scuole primarie.</p>
            <p>La proposta include materiali didattici, esercizi di osservazione e suggerimenti per prolungare l’esperienza in classe.</p>
            <a class="button primary" href="/">Torna alla homepage</a>
          </div>
        </section>
      </main>


</BaseLayout>
