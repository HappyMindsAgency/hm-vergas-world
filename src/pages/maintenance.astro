---
// Splash "Sito in manutenzione". Servita dal middleware (rewrite) per qualunque
// percorso quando MAINTENANCE_ENABLED è true e non c'è bypass. Status 503 per i crawler.
// Il logo è un ASSET STATICO (/immagini): il filesystem lo serve PRIMA del middleware,
// quindi si carica anche in manutenzione. NB: NON inlinearlo come data URI base64 —
// una data URI grande gonfia la pagina e su Vercel (edge middleware) rompe la resa.
Astro.response.status = 503;
Astro.response.headers.set("retry-after", "3600");
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Verga's World</title>
    <style>
      :root { --cream:#F8F4EC; --ink:#352516; --muted:#6b5d4f; --red:#E84C35; --blue:#4E98CA; }
      * { box-sizing: border-box; }
      html, body { height:100%; margin:0; }
      body {
        display:flex; align-items:center; justify-content:center; padding:24px;
        background:var(--cream); color:var(--ink);
        font-family: 'Outfit', system-ui, -apple-system, 'Segoe UI', Arial, sans-serif;
        text-align:center;
      }
      .card { max-width:560px; }
      .logo { width:260px; max-width:74%; height:auto; display:block; margin:0 auto 20px; }
      h1 { font-family: Georgia, 'Times New Roman', serif; font-weight:600; font-size:2rem; color:var(--blue); margin:8px 0 12px; }
      p { font-size:1.05rem; line-height:1.6; color:var(--muted); margin:0 auto; max-width:44ch; }
    </style>
  </head>
  <body>
    <div class="card">
      <img class="logo" src="/immagini/figma-logo-vergas-world.png" alt="Verga's World" width="606" height="243" />
      <h1>Verga’s World sta arrivando</h1>
      <p>Un mondo di storie, personaggi e piccoli misteri ambientati a Vizzini sta per aprire le sue porte.</p>
      <p>Coming soon!</p>
    </div>
  </body>
</html>
