---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import "../../../../styles/adventure.css";

---

<BaseLayout
  title="Missione | Verga's World"
  fonts="adventure"
  scripts={[{ src: "/scripts/quiz-data.js" }, { src: "/scripts/adventure.js" }]}
  page="mission"
>
  <main id="main-content" class="mission-page">
        <header class="mission-header">
          <div>
            <p data-mission-story>La Lupa</p>
            <strong><span data-question-index>1</span> / 5</strong>
          </div>
          <div class="mission-progress"><span data-mission-progress></span></div>
        </header>
        <section class="quiz-card">
          <h1 data-question-text></h1>
          <div class="options-grid" data-options-grid></div>
          <p class="quiz-feedback" data-quiz-feedback></p>
          <button class="next-question" type="button" data-next-question hidden>Prossima domanda →</button>
        </section>
        <section class="mission-complete" data-mission-complete hidden>
          <div class="falling-badge" data-complete-badge></div>
          <h1 data-complete-title>Hai conquistato il badge!</h1>
          <a href="/avventura/passaporto">Torna al Passaporto</a>
        </section>
      </main>


</BaseLayout>
