---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import "../../../styles/adventure.css";

---

<BaseLayout
  title="Passaporto | Verga's World"
  fonts="adventure"
  scripts={[{ src: "/scripts/adventure.js" }]}
  page="passport"
>
  <main id="main-content" class="passport-page">
        <header class="passport-header">
          <a href="/">Verga's World</a>
          <a href="/avventura">Cambia codice</a>
        </header>
        <section class="passport-layout">
          <aside class="explorer-card">
            <div class="avatar-initial" data-avatar-initial>V</div>
            <h1 data-explorer-name>Esploratore</h1>
            <span class="rank-pill" data-rank>Esploratore Principiante</span>
            <div class="progress-copy"><span data-completed-count>0</span> / 7 missioni completate</div>
            <div class="progress-track"><span data-progress-bar></span></div>
            <button type="button" data-change-name>Cambia nome</button>
          </aside>
          <section class="badges-area">
            <div class="section-title">
              <p>Il tuo passaporto</p>
              <h2>I 7 badge</h2>
            </div>
            <div class="badge-grid" data-badge-grid></div>
            <div class="passport-footer" data-passport-footer></div>
          </section>
        </section>
      </main>
      <dialog class="badge-modal" data-badge-modal>
        <button type="button" data-close-modal>Chiudi</button>
        <img decoding="async" loading="lazy" data-modal-img alt="" />
        <h2 data-modal-title></h2>
        <p data-modal-text></p>
      </dialog>


</BaseLayout>
