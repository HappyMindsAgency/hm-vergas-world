---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import "../../../styles/teacher.css";

const body = "<div class=\"teacher-layout\">\n      <aside class=\"teacher-sidebar\">\n        <a class=\"sidebar-logo\" href=\"/\"><span class=\"brand-mark\">VW</span><span><strong>Verga's World</strong><small>Docenti</small></span></a>\n        <div class=\"teacher-meta\"><strong>Prof.ssa Rossi</strong><span>Classe 2B · I.C. Vizzini</span></div>\n        <nav class=\"sidebar-nav\"><a href=\"/insegnante/dashboard\">Dashboard</a><a href=\"/insegnante/classe\">La mia classe</a><a class=\"is-active\" href=\"/insegnante/materiali\">Materiali</a><a href=\"/insegnante/impostazioni\">Impostazioni</a></nav>\n        <a class=\"sidebar-exit\" href=\"/insegnante/login\">Esci</a>\n      </aside>\n      <main id=\"main-content\" class=\"teacher-main\">\n        <header class=\"page-header\"><h1>Materiali</h1><p>PDF statici pronti per la classe, organizzati per momento didattico.</p></header>\n        <section class=\"dashboard-panel\"><div class=\"panel-heading\"><h2>Prima della visita</h2></div><div class=\"materials-grid\">\n          <article class=\"file-card\"><span>📄</span><strong>Guida per l'insegnante</strong><small>PDF · 8 pagine · /public/materiali/guida-insegnante.pdf</small><button type=\"button\">Scarica →</button></article>\n          <article class=\"file-card\"><span>📄</span><strong>Scheda introduttiva su Giovanni Verga</strong><small>PDF · 2 pagine</small><button type=\"button\">Scarica →</button></article>\n          <article class=\"file-card\"><span>📄</span><strong>Le parole di Verga</strong><small>PDF stampabile · attività pre-visita</small><button type=\"button\">Scarica →</button></article>\n        </div></section>\n        <section class=\"dashboard-panel\"><div class=\"panel-heading\"><h2>Percorsi tematici</h2></div><div class=\"materials-grid\">\n          <article class=\"file-card\"><span>🌿</span><strong>La libertà</strong><small>La Lupa + Cavalleria Rusticana</small><button type=\"button\">Scarica →</button></article>\n          <article class=\"file-card\"><span>💪</span><strong>Il coraggio</strong><small>Rosso Malpelo</small><button type=\"button\">Scarica →</button></article>\n          <article class=\"file-card\"><span>👨‍👩‍👧</span><strong>La famiglia</strong><small>I Malavoglia</small><button type=\"button\">Scarica →</button></article>\n          <article class=\"file-card\"><span>🌾</span><strong>La natura</strong><small>Percorso ambientale trasversale</small><button type=\"button\">Scarica →</button></article>\n          <article class=\"file-card\"><span>⚖️</span><strong>Le scelte difficili</strong><small>Mastro-don Gesualdo</small><button type=\"button\">Scarica →</button></article>\n        </div></section>\n        <section class=\"dashboard-panel\"><div class=\"panel-heading\"><h2>Dopo la visita</h2></div><div class=\"materials-grid\">\n          <article class=\"file-card\"><span>📄</span><strong>Lezione di restituzione</strong><small>PDF · suggerimenti</small><button type=\"button\">Scarica →</button></article>\n          <article class=\"file-card\"><span>📄</span><strong>Schede discussione storie</strong><small>7 PDF · una scheda per storia</small><button type=\"button\">Scarica →</button></article>\n          <article class=\"file-card\"><span>🖨️</span><strong>Diploma da stampare</strong><small>Versione insegnante</small><button type=\"button\">Scarica →</button></article>\n        </div></section>\n      </main>\n    </div>\n    <nav class=\"bottom-nav\"><a href=\"/insegnante/dashboard\"><span>⌂</span>Dashboard</a><a href=\"/insegnante/classe\"><span>●</span>Classe</a><a href=\"/insegnante/materiali\"><span>□</span>Materiali</a><a href=\"/insegnante/login\"><span>↗</span>Esci</a></nav>";
---

<BaseLayout
  title="Materiali | Verga's World"
  fonts="main"
  scripts={[]}
>
  <Fragment set:html={body} />

</BaseLayout>
