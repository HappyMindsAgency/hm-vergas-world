---
// Impostazioni (§9.3): il docente cambia la propria email/password. SSR protetto.
export const prerender = false;

import DocenteLayout from "../../../layouts/DocenteLayout.astro";
import { getTeacherProfile } from "../../../lib/docenti/session";

const teacher = await getTeacherProfile(Astro.cookies);
if (!teacher) return Astro.redirect("/insegnante/login");
const teacherName = `${teacher.nome} ${teacher.cognome}`.trim();
---

<DocenteLayout title="Impostazioni | Area Docenti" active="/insegnante/impostazioni" teacherName={teacherName} teacherSubtitle="Docente">
  <header class="mb-4">
    <h1 class="font-heading d-title display-6 mb-1">Impostazioni</h1>
    <p class="mb-0" style="color:var(--d-ink)">Aggiorna le credenziali del tuo account.</p>
  </header>

  <div id="page-alert" class="alert d-none" role="alert"></div>

  <section class="d-card p-4" style="max-width:640px">
    <h2 class="font-heading d-title h4 mb-3">Il mio account</h2>
    <hr style="border-color:var(--d-border)" />
    <form id="self-form" class="row g-3">
      <div class="col-12">
        <label class="form-label stat-label" for="se-nome">Nome</label>
        <input class="form-control" id="se-nome" value={`${teacher.nome} ${teacher.cognome}`.trim()} disabled />
        <div class="form-text">Per cambiare nome o cognome, contatta il museo.</div>
      </div>
      <div class="col-12">
        <label class="form-label stat-label" for="se-email">Email</label>
        <input class="form-control" id="se-email" name="email" type="email" value={teacher.email} />
      </div>
      <div class="col-12">
        <label class="form-label stat-label" for="se-pw">Nuova password (lascia vuoto per non cambiarla)</label>
        <input class="form-control" id="se-pw" name="password" type="password" minlength="8" autocomplete="new-password" />
      </div>
      <div class="col-12">
        <button class="btn btn-d-blue px-4" type="submit">Salva modifiche</button>
      </div>
    </form>
  </section>

  <script>
    const pageAlert = document.getElementById("page-alert")!;
    function notify(msg: string, ok = true) {
      pageAlert.classList.remove("d-none", "alert-success", "alert-danger");
      pageAlert.classList.add(ok ? "alert-success" : "alert-danger");
      pageAlert.textContent = msg;
    }

    document.getElementById("self-form")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target as HTMLFormElement);
      const payload: Record<string, unknown> = { email: fd.get("email") };
      const pw = String(fd.get("password") ?? "");
      if (pw) payload.password = pw;
      const res = await fetch("/api/insegnante/impostazioni", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      const body = await res.json().catch(() => ({}));
      notify(res.ok ? "Account aggiornato." : (body.error ?? "Aggiornamento non riuscito."), res.ok);
    });
  </script>
</DocenteLayout>
