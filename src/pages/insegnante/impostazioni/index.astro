---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import "../../../styles/teacher.css";

const body = "<div class=\"teacher-layout\">\n      <aside class=\"teacher-sidebar\">\n        <a class=\"sidebar-logo\" href=\"/\"><span class=\"brand-mark\">VW</span><span><strong>Verga's World</strong><small>Docenti</small></span></a>\n        <div class=\"teacher-meta\"><strong>Prof.ssa Rossi</strong><span>Classe 2B · I.C. Vizzini</span></div>\n        <nav class=\"sidebar-nav\"><a href=\"/insegnante/dashboard\">Dashboard</a><a href=\"/insegnante/classe\">La mia classe</a><a href=\"/insegnante/materiali\">Materiali</a><a class=\"is-active\" href=\"/insegnante/impostazioni\">Impostazioni</a></nav>\n        <a class=\"sidebar-exit\" href=\"/insegnante/login\">Esci</a>\n      </aside>\n      <main id=\"main-content\" class=\"teacher-main\">\n        <header class=\"page-header\"><h1>Impostazioni</h1><p>Gestisci account, classe e preferenze senza modificare i dati emessi dal museo.</p></header>\n        <section class=\"settings-grid\">\n          <article class=\"card settings-block\"><h2>Il mio account</h2><form class=\"settings-form\"><label class=\"field\">Nome visualizzato<input value=\"Prof.ssa Rossi\" /></label><label class=\"field\">Email<input value=\"rossi@scuola.it\" disabled /></label><button class=\"primary-button\" type=\"button\">Cambia password</button></form></article>\n          <article class=\"card settings-block\"><h2>La mia classe</h2><form class=\"settings-form\"><label class=\"field\">Nome classe<input value=\"2B\" /></label><div class=\"code-display\"><strong>VIZZINI-2B-1880</strong><button class=\"secondary-button\" type=\"button\" data-copy-code>Copia</button><button class=\"secondary-button\" type=\"button\">Stampa cartoncino</button></div><label class=\"field\">Scadenza codice<input value=\"30/06/2026\" disabled /></label><button class=\"primary-button\" type=\"button\">Richiedi nuovo codice</button></form></article>\n          <article class=\"card settings-block\"><h2>Lingua</h2><p>La preferenza viene salvata localmente sul dispositivo.</p><div class=\"toggle-row\"><button class=\"is-active\" type=\"button\" data-lang=\"it\">Italiano</button><button type=\"button\" data-lang=\"en\">English</button></div></article>\n        </section>\n      </main>\n    </div>\n    <nav class=\"bottom-nav\"><a href=\"/insegnante/dashboard\"><span>⌂</span>Dashboard</a><a href=\"/insegnante/classe\"><span>●</span>Classe</a><a href=\"/insegnante/materiali\"><span>□</span>Materiali</a><a href=\"/insegnante/login\"><span>↗</span>Esci</a></nav>\n    <div class=\"toast\" data-toast hidden>Codice copiato</div>";
---

<BaseLayout
  title="Impostazioni | Verga's World"
  fonts="main"
  scripts={[{ src: "/scripts/teacher.js" }]}
>
  <Fragment set:html={body} />

</BaseLayout>
