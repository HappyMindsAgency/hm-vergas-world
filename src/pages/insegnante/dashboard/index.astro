---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import "../../../styles/teacher.css";

const body = "<div class=\"teacher-layout\">\n      <aside class=\"teacher-sidebar\">\n        <a class=\"sidebar-logo\" href=\"/\"><span class=\"brand-mark\">VW</span><span><strong>Verga's World</strong><small>Docenti</small></span></a>\n        <div class=\"teacher-meta\"><strong>Prof.ssa Rossi</strong><span>Classe 2B · I.C. Vizzini</span></div>\n        <nav class=\"sidebar-nav\" aria-label=\"Menu insegnante\">\n          <a class=\"is-active\" href=\"/insegnante/dashboard\">Dashboard</a>\n          <a href=\"/insegnante/classe\">La mia classe</a>\n          <a href=\"/insegnante/materiali\">Materiali</a>\n          <a href=\"/insegnante/impostazioni\">Impostazioni</a>\n        </nav>\n        <a class=\"sidebar-exit\" href=\"/insegnante/login\">Esci</a>\n      </aside>\n\n      <main id=\"main-content\" class=\"teacher-main\">\n        <header class=\"page-header\">\n          <h1>Ciao, Prof.ssa Rossi</h1>\n          <p>La classe 2B sta esplorando Verga's World.</p>\n          <span>Ultima attività: ieri alle 16:42</span>\n        </header>\n\n        <section class=\"metric-grid\" aria-label=\"Riepilogo rapido\">\n          <article class=\"metric-card\"><span>Bambini attivi</span><strong>18 / 23</strong></article>\n          <article class=\"metric-card\"><span>Missioni completate</span><strong>47 / 161</strong></article>\n          <article class=\"metric-card\"><span>Badge conquistati</span><strong>34</strong></article>\n          <article class=\"metric-card\"><span>Diplomi scaricati</span><strong>6</strong></article>\n        </section>\n\n        <section class=\"dashboard-panel\">\n          <div class=\"panel-heading\"><h2>Quanti bambini hanno completato ogni storia?</h2></div>\n          <div class=\"story-bars\">\n            <div class=\"story-row\"><strong>Carletto arriva a Vizzini</strong><div class=\"bar-track\"><span class=\"bar-fill\" style=\"width: 78%\"></span></div><span>18/23 · 78%</span></div>\n            <div class=\"story-row\"><strong>La Lupa</strong><div class=\"bar-track\"><span class=\"bar-fill\" style=\"width: 65%\"></span></div><span>15/23 · 65%</span></div>\n            <div class=\"story-row\"><strong>I Malavoglia</strong><div class=\"bar-track\"><span class=\"bar-fill\" style=\"width: 56%\"></span></div><span>13/23 · 56%</span></div>\n            <div class=\"story-row\"><strong>Cavalleria Rusticana</strong><div class=\"bar-track\"><span class=\"bar-fill\" style=\"width: 48%\"></span></div><span>11/23 · 48%</span></div>\n            <div class=\"story-row\"><strong>Rosso Malpelo</strong><div class=\"bar-track\"><span class=\"bar-fill\" style=\"width: 39%\"></span></div><span>9/23 · 39%</span></div>\n            <div class=\"story-row\"><strong>Mastro-don Gesualdo</strong><div class=\"bar-track\"><span class=\"bar-fill\" style=\"width: 30%\"></span></div><span>7/23 · 30%</span></div>\n            <div class=\"story-row\"><strong>Il segreto di Marco</strong><div class=\"bar-track\"><span class=\"bar-fill\" style=\"width: 22%\"></span></div><span>5/23 · 22%</span></div>\n          </div>\n          <div class=\"suggestion-box\">\n            Suggerimento per la classe: \"Rosso Malpelo\", \"Mastro-don Gesualdo\" e \"Il segreto di Marco\" sono le storie meno esplorate. Considera di dedicare 10 minuti in classe alla discussione di questi temi.\n          </div>\n        </section>\n\n        <section class=\"dashboard-panel\">\n          <div class=\"panel-heading\">\n            <h2>Ultime attività</h2>\n            <a class=\"secondary-button\" href=\"/insegnante/classe\">Vedi tutta l'attività</a>\n          </div>\n          <div class=\"activity-feed\">\n            <div class=\"activity-item\"><span class=\"dot badge\"></span><span><strong>Giulia</strong> ha conquistato il badge \"La Lupa\"</span><time>oggi, 14:32</time></div>\n            <div class=\"activity-item\"><span class=\"dot done\"></span><span><strong>Marco</strong> ha completato la missione \"I Malavoglia\"</span><time>oggi, 11:15</time></div>\n            <div class=\"activity-item\"><span class=\"dot\"></span><span><strong>Sofia</strong> ha scaricato il diploma</span><time>ieri, 18:44</time></div>\n            <div class=\"activity-item\"><span class=\"dot done\"></span><span><strong>Luca</strong> ha iniziato la missione \"Rosso Malpelo\"</span><time>ieri, 16:20</time></div>\n          </div>\n        </section>\n      </main>\n    </div>\n\n    <nav class=\"bottom-nav\" aria-label=\"Menu mobile\">\n      <a href=\"/insegnante/dashboard\"><span>⌂</span>Dashboard</a>\n      <a href=\"/insegnante/classe\"><span>●</span>Classe</a>\n      <a href=\"/insegnante/materiali\"><span>□</span>Materiali</a>\n      <a href=\"/insegnante/login\"><span>↗</span>Esci</a>\n    </nav>";
---

<BaseLayout
  title="Dashboard Insegnante | Verga's World"
  fonts="main"
  scripts={[{ src: "/scripts/teacher.js" }]}
>
  <Fragment set:html={body} />

</BaseLayout>
