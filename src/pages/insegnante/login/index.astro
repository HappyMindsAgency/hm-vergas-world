---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import "../../../styles/teacher.css";
---

<BaseLayout
  title="Login Insegnante | Verga's World"
  fonts="main"
  scripts={[{ src: "/scripts/teacher.js" }]}
  bodyClass="auth-page"
>
  <main id="main-content" class="auth-card">
    <a class="auth-logo" href="/" aria-label="Verga's World">
      <span class="brand-mark">VW</span>
      <span><strong>Verga's World</strong><small>Area docenti</small></span>
    </a>
    <h1>Bentornato/a, professore!</h1>
    <p>Accedi per vedere come sta andando la tua classe.</p>
    <form class="auth-form" action="../dashboard/">
      <label class="field">Email<input type="email" name="email" autocomplete="email" required /></label>
      <label class="field">Password<input type="password" name="password" autocomplete="current-password" required /></label>
      <button class="primary-button" type="submit">Entra nel cruscotto</button>
    </form>
    <div class="auth-help">
      <button class="text-button" type="button" data-open-help>Hai problemi ad accedere?</button>
    </div>
    <div class="auth-note">
      Primo accesso? Usa il link di invito ricevuto dal museo. Demo: <a href="/invito?token=demo">apri invito</a>.
    </div>
  </main>

  <div class="modal" data-help-modal hidden>
    <div class="modal-card">
      <h2>Accesso su invito</h2>
      <p>Se il link e scaduto o non ricordi la password, contatta il Museo Casa Verga.</p>
      <p><strong>Email:</strong> museo@vergasworld.it</p>
      <button class="primary-button" type="button" data-close-help>Ho capito</button>
    </div>
  </div>
</BaseLayout>
