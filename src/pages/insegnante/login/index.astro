---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import "../../../styles/teacher.css";

const body = "<main id=\"main-content\" class=\"auth-card\">\n      <a class=\"auth-logo\" href=\"/\" aria-label=\"Verga's World\">\n        <span class=\"brand-mark\">VW</span>\n        <span><strong>Verga's World</strong><small>Area docenti</small></span>\n      </a>\n      <h1>Bentornato/a, professore!</h1>\n      <p>Accedi per vedere come sta andando la tua classe.</p>\n      <form class=\"auth-form\" action=\"../dashboard/\">\n        <label class=\"field\">Email<input type=\"email\" name=\"email\" autocomplete=\"email\" required /></label>\n        <label class=\"field\">Password<input type=\"password\" name=\"password\" autocomplete=\"current-password\" required /></label>\n        <button class=\"primary-button\" type=\"submit\">Entra nel cruscotto</button>\n      </form>\n      <div class=\"auth-help\">\n        <button class=\"text-button\" type=\"button\" data-open-help>Hai problemi ad accedere?</button>\n      </div>\n      <div class=\"auth-note\">\n        Primo accesso? Usa il link di invito ricevuto dal museo. Demo: <a href=\"/invito?token=demo\">apri invito</a>.\n      </div>\n    </main>\n\n    <div class=\"modal\" data-help-modal hidden>\n      <div class=\"modal-card\">\n        <h2>Accesso su invito</h2>\n        <p>Se il link e scaduto o non ricordi la password, contatta il Museo Casa Verga.</p>\n        <p><strong>Email:</strong> museo@vergasworld.it</p>\n        <button class=\"primary-button\" type=\"button\" data-close-help>Ho capito</button>\n      </div>\n    </div>";
---

<BaseLayout
  title="Login Insegnante | Verga's World"
  fonts="main"
  scripts={[{ src: "/scripts/teacher.js" }]}
  bodyClass="auth-page"
>
  <Fragment set:html={body} />

</BaseLayout>
