# Verga's World — variabili d'ambiente. COPIA in .env (ignorato da git) e riempi.
# NESSUN segreto va committato. Su Vercel: Environment Variables.

# --- Supabase ---
# PUBLIC_* sono esposte al client (solo anon). URL del progetto Supabase.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
# SOLO server-side. Mai esporre al client. Bypassa RLS.
SUPABASE_SERVICE_ROLE_KEY=

# --- SMTP (nodemailer, inviti docente + reset password) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Verga's World <no-reply@vergasworld.it>
